<?xml version="1.0" encoding="UTF-8"?>

<SimulationModelIncludeFile>
<!--PlantTemplate-->
	<SimulaDirective path="/soil">
		<!-- <SimulaExternal name="Simunek" unit="noUnit" function="Simunek" />-->
		<!--SimulaVariable name="potentialTranspiration" unit="cm3" function="sumOverPlantsShootRates" />
		<SimulaVariable name="actualTranspiration" unit="cm3" function="sumOverPlantsShootRates" /-->
	</SimulaDirective>	


	<SimulaDirective path="/plantTemplate">
		<SimulaVariable name="rootWaterUptake" unit="cm3" function="plantTotalRatesRootFraction" />
		<SimulaVariable name="rootWaterUptakeCheck" unit="cm3" function="waterUptakeDoussanModel" />
		<SimulaTable name_colum1="time" name_colum2="waterPotentialAtTheCollar" unit_colum1="day" unit_colum2="hPa" function="getValuesFromPlantWaterUptake">
		   -1 0 
		</SimulaTable>
		<SimulaDerivative name="rootSystemHydraulicConductivity1" unit="cm3/day/g/hPa" function="hydraulicConductivityRootSystem" />
		<SimulaDerivative name="rootSystemHydraulicConductivity2" unit="cm3/day/cm2/hPa" function="hydraulicConductivityRootSystem" />
		<SimulaDerivative name="rootSystemHydraulicConductivity3" unit="cm3/day/cm3/hPa" function="hydraulicConductivityRootSystem" />
	</SimulaDirective>	

<!--ShootTemplate-->
	<SimulaDirective path="/shootTemplate">
		<SimulaVariable name="potentialTranspiration" unit="cm3" function="potentialTranspirationCrop"/>
	</SimulaDirective>

<!--HypocotylTemplate-->
	<SimulaDirective path="/hypocotylTemplate">
		<SimulaDirective path="growthpoint">
			<SimulaConstant name="rootSegmentWaterUptake" unit="cm3">0</SimulaConstant>
		</SimulaDirective>
		<SimulaVariable name="rootWaterUptake" unit="cm3" function="rootTotalRates" />
		<SimulaVariable name="rootSystemWaterUptake" unit="cm3" function="rootSystemTotalRates" />
	</SimulaDirective>

<!--Sibling root template-->
	<SimulaDirective path="/siblingRootTemplate">
		<SimulaDirective path="growthpoint">
			<SimulaConstant name="rootSegmentWaterUptake" unit="cm3">0</SimulaConstant>
			<SimulaConstant name="rootSegmentPotentialWaterUptake" unit="cm3">0</SimulaConstant>
		</SimulaDirective>
		<SimulaVariable name="rootWaterUptake" unit="cm3" function="rootTotalRates" />
		<SimulaVariable name="rootSystemWaterUptake" unit="cm3" function="rootSystemTotalRates" />
	</SimulaDirective>

<!--DataPointTemplate-->
	<SimulaDirective path="/dataPointTemplate">
		<!-- SimulaVariable name="rootWaterUptake" unit="cm3/cm" function="scaledWaterUptake" /-->
		<SimulaVariable name="rootSegmentWaterUptake" unit="cm3" function="useDerivative" />
		<SimulaTable name_colum1="time" name_colum2="rootSegmentWaterUptakeRate" unit_colum1="day" unit_colum2="cm3/day" function="getValuesFromPlantWaterUptake">
		  -100000 0
		</SimulaTable>
		<SimulaTable name_colum1="time" name_colum2="hydraulicHeadAtRootSurface" unit_colum1="day" unit_colum2="cm" function="getValuesFromSWMS" />
		 <!-- 0 -400 1 -700 2 -300 3 -700 4 -300 5 -600 7 -1000 8 -100  50 -1000 -->
<!--		    0 -100 100 -100  
		</SimulaTable-->
		<SimulaTable name_colum1="time" name_colum2="xylemWaterPotential" unit_colum1="day" unit_colum2="cm" function="getValuesFromPlantWaterUptake" >
			-100000 0
		</SimulaTable>
		<SimulaTable name_colum1="time" name_colum2="volumetricWaterContentAtTheRootSurface" unit_colum1="day" unit_colum2="cm3/cm3" function="getValuesFromSWMS" integrationFunction="BackwardEuler" minTimeStep="0.1" maxTimeStep="0.1" preferedTimeStep="0.101"/>
<!-- 		    0 -100 100 -100  
		</SimulaTable-->
		
		<SimulaLink name="radialHydraulicConductivity" unit="cm/day/hPa" />
		<SimulaLink name="lateralHydraulicConductivity" unit="cm4/day/hPa" />
		<SimulaDerivative name="rootSegmentLateralHydraulicConductivity" unit="cm3/day/hPa" function="hydraulicConductivity"/>
		<SimulaDerivative name="rootSegmentRadialHydraulicConductivity" unit="cm3/day/hPa" function="hydraulicConductivity"/>
		<!-- SimulaLink name="lengthRootTipWithoutXylemVessels" unit="cm" /-->
	</SimulaDirective>
</SimulationModelIncludeFile>

