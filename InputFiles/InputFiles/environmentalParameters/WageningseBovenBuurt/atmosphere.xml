<!--SimRoot parameter file-->
<SimulationModelIncludeFile>
<!--environmental parameters start here. -->
	<SimulaDirective path="environment">
		<SimulaBase name="atmosphere">
			<SimulaConstant name="irradiation"  unit="uMol/cm2/day" note="par/rdd in lintul"> 
					4000
			  <!-- average estimate for green houses tyson 800 uMol/m2/s  = 3456.0 uMol/cm2/day (12 hour light)
			  5184 for 1200uMol/m2/s
			 average Raul experiment 2006 green houses tyson 590 uMol/m2/s measurements taken from 10am-1pm 
			    2548.8 uMol/cm2/day (based on 12 hour day)
			    about 25% less because of mornings and evenings ?
			    		   
              2.8330E-3 Mj/cm2/d sunny summers day in the Netherlands: day 190 year 1999 data KNMI ; NOTE: use PAR/RDD ratio of 0.5--> 
			</SimulaConstant>
			<SimulaConstant name="PAR/RDD"  unit="100%" >
			<!--note="optional conversion factor from RDD to PAR - normally 0.5; only used if irradiation isn't converted yet otherwise set to 1"--> 
					1. 
			</SimulaConstant>
			<SimulaTable name_colum2="precipitation" name_colum1="time" unit_colum1="day" unit_colum2="cm/day" interpolationMethod="step"> 
			  <!--
			  Rocksprings, PA, maize season 2009
			  1 0 2 1 3 0.29 4	0 5 0 6 0.61 7 0 8 0 9 0.25 10 0.03 11 0 12 0.64 13 0.33 14 0 15 0 16 0 17 0 18 1.8 19 0.2 20 0 21 2.84 22 0.38 23 0
				24 0 25 0 26 0 27 0.18 28 0 29 0.46 30 0 31 1.35 32 0.13 33 0.23 34 0.25 35 0 36 0 37 0 38 0 39 0 40 0 41 0 42 1.42 -->
				0 0 1 0 2 1 3 0.29 4	0 5 0 6 0.61 7 0 8 0 9 0.25 10 0.03 11 0 12 0.64 13 0.33 14 0 15 0 16 0 17 0 18 1.8 19 0.2 20 0 21 2.84 22 0.38 23 0
				24 0 25 0 26 0 27 0.18 28 0 29 0.46 30 0 31 1.35 32 0.13 33 0.23 34 0.25 35 0 36 0 37 0 38 0 39 0 40 0 41 0 42 1.42
				
			</SimulaTable>
			<SimulaTable name_colum2="evaporation" name_colum1="time" unit_colum1="day" unit_colum2="cm" interpolationMethod="step">
			<!--this is 'estimated' data for rocksprings: not so accurate -->
			<!--	0 0 1 0.05 2 0.1 3 0.1 4 0.05 5 0.05 6 0.1 7 0.05 8 0.05 9 0.1 10 0.1 11 0.05 12 0.1 13 0.1 14 0.05 15 0.04 16 0.03 17 0.02
				18 0.09 19 0.09 20 0.04 21 0.09 22 0.09 23 0.04 24 0.03 25 0.02 26 0.02 27 0.08 28 0.03 29 0.08 30 0.03 31 0.08 32 0.07
				33 0.07 34 0.07 35 0.03 36 0.02 37 0.01 38 0 39 0 40 0 41 0 42 0.06-->
				0 0.0 10 0 100 0
			</SimulaTable>
		
		<!-- for pennman monteith -->
<!-- numbers need to be checked -->
			<SimulaConstant name="netRadiationSoil" unit="W/m2"> 150 </SimulaConstant>
			<SimulaConstant name="netRadiation" unit="W/m2"> 150 </SimulaConstant>
			<SimulaConstant name="windSpeed" unit="m/s"> 2. </SimulaConstant>
			<SimulaConstant name="relativeHumidity" unit="m/s"> 60 </SimulaConstant>
			<SimulaTable name_colum2="averageDailyTemperature" name_colum1="time" unit_colum1="day" unit_colum2="degreesC"
				interpolationMethod="linear">
				0 16.9
				100 16.9
			</SimulaTable>

<!-- these are necessary to compute incoming radiation by the radiation module -->
			<SimulaConstant name="albedoSoil" unit="noUnit"> 0.17 </SimulaConstant>
			<SimulaConstant name="albedoCrop" unit="noUnit"> 0.23 </SimulaConstant>
			<!-- 0.23 grass 0.17 bare soil 0.05 open water 0.4 desert sand -->
			<SimulaConstant name="altitude" unit="m"> 91 </SimulaConstant>
			<SimulaConstant name="startDay" unit="noUnit" type="int"> 22 </SimulaConstant>
			<SimulaConstant name="startMonth" unit="noUnit" type="int"> 6 </SimulaConstant>
			<SimulaConstant name="latitude" unit="noUnit"> 50.8 </SimulaConstant>
			<SimulaTable name_colum2="actualDurationofSunshine" name_colum1="time" unit_colum1="day" unit_colum2="hour"
				interpolationMethod="step">
				<!-- time of the day that there are no clouds -->
				0 6
				60 6
			</SimulaTable>

		
		</SimulaBase>

		
		
	</SimulaDirective>
</SimulationModelIncludeFile>

		
